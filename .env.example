REDIS_KEY_PREFIX=hangban
LIVE_DEFAULT_BBOXES=100,20,130,50
INGEST_INTERVAL_MS=10000
INGESTOR_LEASE_TTL_MS=30000
INGESTOR_LEASE_RENEW_MS=10000
